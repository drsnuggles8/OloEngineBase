  # ═══ Right receding row ═══
  - Entity: 800000000000030
    TagComponent:
      Tag: Recede R 0
    TransformComponent:
      Translation: [4, 0.2, -2]
      Rotation: [0, -0.3, 0]
      Scale: [1, 1, 1]
    VirtualMeshComponent:
      Enabled: true
      MeshSource: 4544736348022301228
      ErrorThresholdPixels: 1
      CastShadows: true
  - Entity: 800000000000031
    TagComponent:
      Tag: Recede R 1
    TransformComponent:
      Translation: [4, 0.2, -9]
      Rotation: [0, -0.3, 0]
      Scale: [1, 1, 1]
    VirtualMeshComponent:
      Enabled: true
      MeshSource: 4544736348022301228
      ErrorThresholdPixels: 1
