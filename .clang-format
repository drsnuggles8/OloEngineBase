Language: Cpp
BasedOnStyle: LLVM

# Indentation and Tabs
IndentWidth: 4
TabWidth: 4
UseTab: Never
IndentCaseLabels: true
NamespaceIndentation: All
IndentPPDirectives: None 

# Braces (Allman Style)
BreakBeforeBraces: Allman
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty

# Spacing around Parentheses and Keywords
SpaceBeforeParens: ControlStatements 
SpaceInEmptyParentheses: false
SpacesInParentheses: false

# Pointer/Reference Alignment
PointerAlignment: Left

# Braced Lists / Initializers
Cpp11BracedListStyle: false
SpaceBeforeCpp11BracedList: false

# Construction and Inheritance
SpaceBeforeInheritanceColon: true
SpaceBeforeCtorInitializerColon: true

# Binary Operators and Commas
SpaceBeforeAssignmentOperators: true

# Engine Specific / Overrides
ColumnLimit: 0
SortIncludes: false
SpaceAfterTemplateKeyword: false

# Line Endings: preserve whatever's in the file. CRLF here would force clang-format
# to rewrite every source file on Linux CI (where Git checks out LF) — the rewrite
# trips the pre-commit hook and turns CI red even though locally on Windows it
# silently passes (autocrlf=true means the working tree is already CRLF). DeriveLF
# picks LF unless the file already starts with CRLF, so Windows and Linux both end
# up no-op. Real EOL policy lives in .gitattributes (`* text=auto`).
LineEnding: DeriveLF
