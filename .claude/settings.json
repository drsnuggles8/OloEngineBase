{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(cmake --build build --target OloEngine OloEngine-Tests OloEditor --config Debug --parallel)",
      "Bash(gh run *)",
      "Bash(git worktree *)",
      "Bash(build/OloEngine/tests/Debug/OloEngine-Tests.exe)",
      "Bash(tasklist)",
      "Bash(git rebase --abort)",
      "Bash(git rebase --continue)",
      "Bash(git rebase --skip)",
      "Bash(build/OloEngine/tests/Debug/OloEngine-Tests.exe --gtest_filter=\"BoundingBox.*:BoundingSphere.*:BoundingVolume.*:FrustumCulling.*:MeshBinarySerializer.*:MeshSourceBounds.*\")",
      "mcp__sonarqube__get_project_quality_gate_status",
      "mcp__sonarqube__get_component_measures",
      "mcp__sonarqube__search_sonar_issues_in_projects",
      "mcp__sonarqube__show_rule",
      "Bash(cmake --build build --target OloEngine-Tests --config Debug --parallel)"
    ],
    "additionalDirectories": [
      "\\tmp"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/claude-stop-hook.ps1"
          }
        ]
      }
    ]
  },
  "_comment": "Shared Claude Code project settings. Per-user permissions live in settings.local.json (gitignored). Per-user state lives elsewhere in .claude/ (also gitignored)."
}
