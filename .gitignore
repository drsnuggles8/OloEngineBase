# Test failure capture artefacts (machine-specific timestamps / GL strings).
# Captured under whichever CWD the test ran from — OloEditor/ for the editor-
# rooted suites, repo root for tests run via the harness's bare working dir.
OloEditor/assets/tests/captures/
/assets/tests/captures/

# Functional test capture artefacts (scene snapshots on assertion failure)
OloEngine/tests/Functional/captures/

