{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-oloeditor-debug",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloEditor",
				"-Config",
				"Debug"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "build-oloeditor-release",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloEditor",
				"-Config",
				"Release"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "build-oloeditor-dist",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloEditor",
				"-Config",
				"Dist"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "run-oloeditor-debug",
			"type": "shell",
			"command": "${workspaceFolder}/bin/Debug/OloEditor/OloEditor.exe",
			"options": {
				"cwd": "${workspaceFolder}/OloEditor"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "run-oloeditor-release",
			"type": "shell",
			"command": "${workspaceFolder}/bin/Release/OloEditor/OloEditor.exe",
			"options": {
				"cwd": "${workspaceFolder}/OloEditor"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "run-oloeditor-dist",
			"type": "shell",
			"command": "${workspaceFolder}/bin/Dist/OloEditor/OloEditor.exe",
			"options": {
				"cwd": "${workspaceFolder}/OloEditor"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "build-tests-debug",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloEngine-Tests",
				"-Config",
				"Debug"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "run-tests-debug",
			"type": "shell",
			"command": "${workspaceFolder}/build/OloEngine/tests/Debug/OloEngine-Tests.exe",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [],
			"dependsOn": [
				"build-tests-debug"
			]
		},
		{
			"label": "build-oloruntime-debug",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloRuntime",
				"-Config",
				"Debug"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "build-oloruntime-release",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloRuntime",
				"-Config",
				"Release"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "build-oloruntime-dist",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/BuildCleanEnv.ps1",
				"-BuildDir",
				"${workspaceFolder}/build",
				"-Target",
				"OloRuntime",
				"-Config",
				"Dist"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "configure-clangcl",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--preset",
				"clangcl"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "build-clangcl-tests-debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/build-clang",
				"--target",
				"OloEngine-Tests",
				"--config",
				"Debug",
				"--parallel"
			],
			"group": "build",
			"dependsOn": [
				"configure-clangcl"
			],
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "run-clangcl-tests-debug",
			"type": "shell",
			"command": "${workspaceFolder}/build-clang/OloEngine/tests/Debug/OloEngine-Tests.exe",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test",
			"dependsOn": [
				"build-clangcl-tests-debug"
			],
			"problemMatcher": []
		},
		{
			"label": "build-clangcl-oloeditor-debug",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"${workspaceFolder}/build-clang",
				"--target",
				"OloEditor",
				"--config",
				"Debug",
				"--parallel"
			],
			"group": "build",
			"dependsOn": [
				"configure-clangcl"
			],
			"problemMatcher": [
				"$msCompile"
			]
		}
	]
}